# Terrace secrets — copy to `.env` (gitignored). NEVER commit real values.
# For local dev (default) you need NONE of these — the app runs on a throwaway anvil chain
# with test money, and live match data uses TheSportsDB keyless. These are only for Sepolia.

# WDK self-custodial wallet seed (BIP-39). Auto-generated by scripts/wallet-info.mjs if absent.
# Controls your wallet — back it up, never share/commit.
TERRACE_SEED=""

# --- Real Sepolia testnet (optional) ---
SEPOLIA_RPC_URL=""        # e.g. https://sepolia.drpc.org (keyless) — SETTING THIS switches to real testnet
PRIVATE_KEY=""            # funded Sepolia deployer key, ONLY for `./start.sh deploy`. Never paste in chat.
USDT_ADDRESS="0xd077a400968890eacc75cdc901f0356c943e4fdb"  # Sepolia test USDt
ESCROW_ADDRESS=""         # set to the address printed by `./start.sh deploy`
# REPORTER=""             # optional; defaults to the deployer

# --- Live match data (optional) ---
# Keyless by default (TheSportsDB free key). Set a Patreon key for richer data.
# SPORTSDB_KEY=""
# SPORTSDB_LEAGUE="4429"  # FIFA World Cup
